# Sarada Netralaya — Environment Variables
# Copy this file to .env.local and fill in your values.

# Database (SQLite for local dev; use Postgres URL for production/Supabase)
DATABASE_URL=file:./db/custom.db

# Owner dashboard login (single account)
OWNER_EMAIL=owner@saradanetralaya.in
OWNER_PASSWORD=Sarada@2026

# Session secret (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-string

# Telegram bot (optional — leave empty to skip notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
