# Sarada Netralaya — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# IMPORTANT (production): On Vercel, set these in Project → Settings →
# Environment Variables. SESSION_SECRET and OWNER_PASSWORD are REQUIRED
# in production — the app fails closed (admin login impossible) if they
# are missing or weak.

# Database (SQLite for local dev; use Postgres URL for production/Supabase)
DATABASE_URL=file:./db/custom.db

# Owner dashboard login (single account).
# In production, OWNER_PASSWORD must be set — the dev fallback is rejected.
# Use a strong, unique password (this template must never contain a real one).
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-to-a-strong-password

# Session secret — REQUIRED in production (>= 32 chars, strong random).
# Generate with:  openssl rand -base64 48
# If missing/weak in production, all session checks fail closed (admin login
# impossible) and an attacker cannot forge tokens using the dev fallback.
SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars-long

# Telegram bot (optional — leave empty to skip notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

