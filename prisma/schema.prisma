// Sarada Netralaya — production PostgreSQL schema.
// Changes are deployed through committed Prisma migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // pooled (pgbouncer) — used at runtime
  directUrl = env("DIRECT_URL")     // direct connection — used for migrations
}

// Key-value store for editable clinic settings (e.g. consultation fees).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Appointment {
  id             String   @id @default(cuid())
  // Human-friendly booking reference. New bookings use 8 digits; older 6-digit refs remain valid.
  ref            String   @unique
  idempotencyKey String?  @unique
  requestHash    String?
  name           String
  phone          String
  age            Int?
  department     String
  preferredDate  String
  timeSlot       String
  note           String?
  status         String   @default("pending")
  // Consultation fee captured when status first becomes "done".
  feeCharged     Int?
  ipHash         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  version        Int      @default(1)

  @@index([preferredDate])
  @@index([status])
  @@index([phone])
  @@index([preferredDate, createdAt])
  @@index([status, preferredDate])
}

// Durable owner credential override. If absent, OWNER_PASSWORD seeds login.
model OwnerCredential {
  id             String   @id @default("owner")
  passwordHash   String
  sessionVersion Int      @default(1)
  updatedAt      DateTime @default(now()) @updatedAt
}

// Shared serverless rate-limit buckets (never stores raw IP/email/ref values).
model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  updatedAt DateTime @default(now()) @updatedAt

  @@index([resetAt])
}
